{
  "name": "ticketr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "pnpm -r --if-present run test",
    "test:integration": "pnpm -r --if-present run test:integration",
    "build": "pnpm -r --if-present run build",
    "dev:api": "pnpm --filter @ticketr/api dev",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:seed": "pnpm --filter @ticketr/api db:seed",
    "dev:token": "pnpm --filter @ticketr/api dev:token",
    "smoke:api": "pnpm --filter @ticketr/api smoke:api"
  },
  "engines": {
    "node": ">=24.0.0 <25",
    "pnpm": ">=10.12.1 <11"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.12"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
