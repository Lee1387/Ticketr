# Runtime mode for the API. Use "production" in deployed environments.
NODE_ENV=development

# API bind host and port for local development.
API_HOST=0.0.0.0
API_PORT=3000

# Base URL used by local helper scripts that call the running API.
TICKETR_API_URL=http://127.0.0.1:3000

# Local Postgres container settings used by compose.yaml.
POSTGRES_DB=ticketr
POSTGRES_USER=ticketr
POSTGRES_PASSWORD=ticketr
POSTGRES_PORT=5432

# Database connection string used by Drizzle and the API.
# Keep this aligned with the Postgres values above.
DATABASE_URL=postgres://ticketr:ticketr@localhost:5432/ticketr

# Local Redis container port used by compose.yaml.
REDIS_PORT=6379

# Redis connection string used by API infrastructure.
REDIS_URL=redis://localhost:6379

# Secret used to sign and verify local JWTs. Use a long random value.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters

# Expected JWT issuer and audience. Tokens must be signed for these values.
JWT_ISSUER=ticketr
JWT_AUDIENCE=ticketr-api
